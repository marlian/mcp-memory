# mcp-memory — environment configuration
#
# Copy this file to `.env` to customize behavior without touching code.
# All settings are optional; every value has a sensible default.
#
# Precedence (highest to lowest):
#   1. Variables set by the client in its MCP "env": {...} block
#      (supported by most MCP clients — but not all: some clients' schema
#      rejects the `env` key, in which case this .env file is your primary
#      configuration surface)
#   2. Variables from the shell environment
#   3. Values from this .env file
#   4. Hardcoded defaults in server.js
#
# This means: if you also set one of these variables in your client's MCP
# config, the client value wins. The .env file is a fallback for values
# not set elsewhere.

# ---------------------------------------------------------------------------
# Database location
# ---------------------------------------------------------------------------
# Path to the global SQLite database file.
# Default: ./memory.db (next to server.js)
#
# Uncomment and set an absolute path to store the DB outside the repo:
# MEMORY_DB_PATH=/absolute/path/to/memory.db

# ---------------------------------------------------------------------------
# Cognitive decay
# ---------------------------------------------------------------------------
# Half-life for global memory decay, in weeks.
# Facts fade over time unless recalled. Higher values = slower decay.
# A fact never recalled reaches ~50% confidence after this many weeks.
# Default: 12
# MEMORY_HALF_LIFE_WEEKS=12

# Half-life for project-scoped memory decay, in weeks.
# Project knowledge typically stays relevant longer than global facts,
# so the default is much higher.
# Default: 52
# PROJECT_MEMORY_HALF_LIFE_WEEKS=52

# ---------------------------------------------------------------------------
# Compact recall
# ---------------------------------------------------------------------------
# Maximum content length (in characters) when recall is called with compact: true.
# Observations longer than this are truncated and marked with truncated: true.
# Default: 120
# COMPACT_SNIPPET_LENGTH=120

# ---------------------------------------------------------------------------
# Telemetry (opt-in)
# ---------------------------------------------------------------------------
# Path to a separate SQLite database for telemetry logging.
# When set, every tool call is logged with timing, client identity, and
# search ranking metrics. When unset (default), zero telemetry overhead.
#
# The telemetry DB is separate from the memory DB — it never touches your
# knowledge graph. Useful for understanding usage patterns, ranking quality,
# and which clients are calling which tools.
#
# MEMORY_TELEMETRY_PATH=./telemetry.db
